{
  "manifest_version": 3,
  "name": "Polymarket BTC 5m Auto Trader",
  "version": "1.0.0",
  "description": "Automated trading for BTC 5-minute up/down markets",
  "permissions": ["sidePanel"],
  "host_permissions": ["*://*.polymarket.com/*", "ws://localhost:8766/*"],
  "side_panel": {
    "default_path": "sidepanel/index.html"
  }
}
